# Copy this file to .env and fill in real values. Never commit the real .env to GitHub.

# Pick ONE of these and set USE_PROVIDER accordingly
ANTHROPIC_API_KEY=your_anthropic_key_here
GROQ_API_KEY=your_groq_key_here
USE_PROVIDER=anthropic
# USE_PROVIDER=groq

# Where ChromaDB stores its files on disk
CHROMA_PERSIST_DIR=./chroma_data

# Embedding model (downloaded from Hugging Face on first run)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# How similar two mistakes must be (0-1, cosine similarity) before we
# consider them "possibly the same root cause". Tune this in Day 1.
SIMILARITY_THRESHOLD=0.45
